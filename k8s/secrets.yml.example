# Kubernetes Secret Template
# ⚠️  DO NOT COMMIT ACTUAL VALUES - See SECRETS_SETUP.md for proper setup instructions
# This file shows the structure only. Create the actual secrets.yml via:
# - kubectl create secret generic postgres-secret OR
# - Use External Secrets Operator OR
# - Use sealed secrets

apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: default
type: Opaque
stringData:
  POSTGRES_USER: YOUR_USERNAME_HERE
  POSTGRES_PASSWORD: YOUR_PASSWORD_HERE
  POSTGRES_DB: YOUR_DATABASE_HERE
